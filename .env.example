# --- AI (need at least one for "full" Cosmo; otherwise app runs in demo mode) ---

# Anthropic (Claude) — RECOMMENDED: free $5 credit on first signup at console.anthropic.com
# Haiku is cheapest (~$0.80/M tokens); Sonnet is richer but costs more.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# OpenAI (Chat Completions) — fallback if no Anthropic key
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google AI Studio (Gemini) — free tier at aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Force which provider wins when multiple keys exist: anthropic | openai | gemini | mock
# COSMO_LLM_PROVIDER=anthropic

# Force demo replies + keyword routing (no LLM bill)
# COSMO_MOCK_LLM=true

# Optional: higher NASA rate limits than DEMO_KEY
# NASA_API_KEY=

# Optional: TinyFish-style agent (adjust maybeTinyFish in api/_lib/spaceData.ts to match real API)
# TINYFISH_API_URL=
# TINYFISH_API_KEY=
# Fetch NASA audio page via TinyFish, then LLM picks best clip for the child's question (returns meta.nasaSound)
# TINYFISH_NASA_SOUNDS=true
