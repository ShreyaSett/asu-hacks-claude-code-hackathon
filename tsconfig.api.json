{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-api",
    "rootDir": "api",
    "declaration": false,
    "noEmit": true
  },
  "include": ["api/**/*.ts"]
}
